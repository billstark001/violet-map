{
  "name": "violet-map",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "pnpm run dev:full",
    "dev:light": "pnpm --filter=@violet-map/web run dev",
    "dev:full": "pnpm --filter=!@violet-map/assets --parallel -r run dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
